# Normalize line endings on check-in; Git will store everything as LF.
# Checkouts respect the platform (CRLF on Windows, LF elsewhere).
* text=auto eol=lf

# Shell / CI scripts must stay LF everywhere (they're executed on Linux/macOS).
*.sh         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
Makefile     text eol=lf

# Windows-only files — keep CRLF.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Binary blobs — never munge.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.icns       binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.eot        binary
*.pdf        binary
*.exe        binary
*.msi        binary
*.dmg        binary
*.deb        binary
*.AppImage   binary
