{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProSSH",
  "version": "0.1.1",
  "identifier": "pro.prossh.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProSSH",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Cross-platform SSH/SCP client",
    "longDescription": "ProSSH — modern cross-platform SSH/SCP client with tabs, split panes and SFTP file manager.",
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "languages": ["English", "Russian", "SimpChinese"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": {
          "en-US": {},
          "ru-RU": { "localePath": "wix/ru-RU.wxl" },
          "zh-CN": { "localePath": "wix/zh-CN.wxl" }
        }
      }
    }
  }
}
